<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".MGBApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:resizeableActivity="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/AppTheme">
        <activity
            android:name=".EmulatorActivity"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:screenOrientation="fullSensor" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- This is a local ROM file handler, not a web or Android App Link. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:host="*" />
                <data android:pathPattern=".*\\.agb" />
                <data android:pathPattern=".*\\.gba" />
                <data android:pathPattern=".*\\.gb" />
                <data android:pathPattern=".*\\.gbc" />
                <data android:pathPattern=".*\\.sgb" />
                <data android:pathPattern=".*\\.zip" />
                <data android:pathPattern=".*\\.7z" />
                <data android:mimeType="application/octet-stream" />
                <data android:mimeType="application/x-gameboy-rom" />
                <data android:mimeType="application/x-gameboy-color-rom" />
                <data android:mimeType="application/x-gba-rom" />
                <data android:mimeType="application/zip" />
                <data android:mimeType="application/x-7z-compressed" />
            </intent-filter>
        </activity>
        <provider
            android:name=".storage.ScreenshotShareProvider"
            android:authorities="${applicationId}.screenshots"
            android:exported="false"
            android:grantUriPermissions="true" />
    </application>
</manifest>
